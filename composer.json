{
  "name": "azymuthia/security-bundle",
  "description": "Azymuthia Security Bundle: JWT integration and optional domain user wiring for Symfony 7.",
  "license": "proprietary",
  "type": "symfony-bundle",
  "require": {
    "php": ">=8.4",
    "lexik/jwt-authentication-bundle": "^3.0",
    "symfony/framework-bundle": "^7.3",
    "symfony/security-bundle": "^7.3",
    "symfony/uid": "^7.3"
  },
  "require-dev": {
    "ergebnis/composer-normalize": "^2.48",
    "roave/security-advisories": "dev-latest"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Azymuthia\\SecurityBundle\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "ergebnis/composer-normalize": true
    }
  }
}
